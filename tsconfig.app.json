{
  // TypeScript 应用配置文件
  // 用于配置 React 应用源代码的编译选项
  "compilerOptions": {
    // 类型检查信息输出文件路径
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    
    // 编译目标：ES2022 标准
    "target": "ES2022",
    
    // 使用 Object.defineProperty 定义类字段（符合 ES2022 标准）
    "useDefineForClassFields": true,
    
    // 包含的类型库：ES2022、DOM、DOM.Iterable
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    
    // 模块系统：ESNext（使用最新的 ES 模块标准）
    "module": "ESNext",
    
    // 包含 Vite 客户端类型定义
    "types": ["vite/client"],
    
    // 跳过类型库的类型检查（加快编译速度）
    "skipLibCheck": true,

    /* ========== 打包器模式配置 ========== */
    // 模块解析策略：使用打包器模式（适用于 Vite）
    "moduleResolution": "bundler",
    
    // 允许导入 TypeScript 扩展名（.ts, .tsx）
    "allowImportingTsExtensions": true,
    
    // 保持模块语法的字面意思（不进行转换）
    "verbatimModuleSyntax": true,
    
    // 强制检测模块（自动识别 ES 模块和 CommonJS 模块）
    "moduleDetection": "force",
    
    // 不输出编译后的文件（由 Vite 处理）
    "noEmit": true,
    
    // JSX 编译模式：使用 React 17+ 的新 JSX 转换
    "jsx": "react-jsx",

    /* ========== 路径别名配置 ========== */
    // 基础 URL：项目根目录
    "baseUrl": ".",
    
    // 路径映射：@/* 指向 src/* 目录
    // 使用示例：import request from '@/utils/request'
    "paths": {
      "@/*": ["src/*"]
    },

    /* ========== 代码检查配置 ========== */
    // 启用所有严格类型检查
    "strict": true,
    
    // 检查未使用的局部变量
    "noUnusedLocals": true,
    
    // 检查未使用的函数参数
    "noUnusedParameters": true,
    
    // 仅允许可擦除的语法（确保类型可以完全移除）
    "erasableSyntaxOnly": true,
    
    // 检查 switch 语句中是否有遗漏的 case
    "noFallthroughCasesInSwitch": true,
    
    // 检查未检查的副作用导入
    "noUncheckedSideEffectImports": true
  },
  
  // 包含的文件：src 目录下的所有文件
  "include": ["src"]
}
